# ─────────────────────────────────────────────────────────
# Backend Ladurrie — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# ─────────────────────────────────────────────────────────

# Pagou.ai
PAGOU_API_KEY=sk_live_...          # ou sk_sandbox_... para testes
PAGOU_ENVIRONMENT=production       # "sandbox" | "production"

# UTMify  (obrigatório — sem fallback hardcoded)
UTMIFY_API_TOKEN=seu_token_aqui

# URL pública do site (usada para montar o notify_url do webhook)
SITE_URL=https://seudominio.com

# CORS: origens permitidas separadas por vírgula
# Deixe vazio apenas em dev local (aceita tudo)
CORS_ORIGINS=https://seudominio.com,https://www.seudominio.com

# Porta do servidor Express
PORT=3001

# Ambiente Node
NODE_ENV=production
