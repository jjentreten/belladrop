{
  "name": "ladurrie-backend",
  "version": "1.0.0",
  "description": "Backend Node.js/Express para Ladurrie (ex-Netlify Functions)",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
