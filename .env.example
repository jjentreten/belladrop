# Pagou.ai credentials
# Get these from: https://dashboard.pagou.ai/developers

PAGOU_API_KEY=sk_sandbox_your_key_here
PAGOU_ENVIRONMENT=sandbox

# Your site's public URL (used for webhook notify_url)
SITE_URL=https://your-site.netlify.app

# UTMify API token
# Get from: https://app.utmify.com.br/settings/integrations
UTMIFY_API_TOKEN=your_utmify_api_token_here
